rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Détermine si l'utilisateur authentifié fait partie du staff (super admin,
    // admin national, coordinateur de délégation ou gestionnaire d'antenne).
    // Le staff peut consulter et supprimer les fichiers déposés par les
    // partenaires (aperçu côté admin/superadmin/coordinateur).
    function isAdmin() {
      return request.auth != null && (
        // Custom Claim recommandé (défini côté serveur via le SDK Admin).
        request.auth.token.admin == true ||
        // Repli : email administrateur connu.
        request.auth.token.email == "mailprosasha2@gmail.com" ||
        firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid)) ||
        (firestore.exists(/databases/(default)/documents/organizations/$(request.auth.uid)) &&
         firestore.get(/databases/(default)/documents/organizations/$(request.auth.uid)).data.role in
           ['admin', 'super_admin', 'admin_delegation', 'admin_antenne'])
      );
    }

    // Contraintes communes aux fichiers déposés : on autorise tous les types de
    // documents/médias courants (PDF, images, bureautique, archives, audio,
    // vidéo, texte…), avec une limite de taille raisonnable. Le portail étant
    // réservé aux comptes authentifiés, on n'impose pas de liste blanche stricte
    // de types MIME (qui bloquait par ex. .xlsx et .zip).
    function isAllowedFile() {
      return request.resource.size <= 50 * 1024 * 1024;
    }

    // Espace privé des organisations : accès au propriétaire ou aux admins.
    match /dossiers/{userId}/{allPaths=**} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin()) && isAllowedFile();
      allow delete: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Fichiers déposés côté admin (panel super admin / coordinateur), rangés par
    // délégation/antenne. Réservé au staff.
    match /delegations/{allPaths=**} {
      allow read, delete: if isAdmin();
      allow write: if isAdmin() && isAllowedFile();
    }

    // Dépôt public anonyme désactivé : un compte est obligatoire pour
    // téléverser des documents (voir le chemin dossiers/{userId}).
    match /public_uploads/{fileName} {
      allow read, delete: if isAdmin();
      allow create, update: if false;
    }
  }
}
