rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() { return request.auth != null; }
    
    function existing() { return resource.data; }
    function incoming() { return request.resource.data; }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // Safe Admin Email Verification
    function isSuperAdminEmail() {
      return isSignedIn() && 
             request.auth.token != null && 
             'email' in request.auth.token && 
             request.auth.token.email != null && 
             (request.auth.token.email == "mailprosasha2@gmail.com" || 
              request.auth.token.email.matches('(?i)mailprosasha2@gmail\\.com'));
    }

    // Checking if the user has a registered document in Firestore
    function hasUserDoc() {
      return isSignedIn() && exists(/databases/$(database)/documents/organizations/$(request.auth.uid));
    }

    // Safe retrieval of the user profile document data
    function getUser() {
      return get(/databases/$(database)/documents/organizations/$(request.auth.uid)).data;
    }

    // Roles: super_admin / admin (global headquarters), admin_delegation (delegation scope), organization (partners)
    function isSuperAdmin() {
      return isSuperAdminEmail() ||
             (isSignedIn() && 'admin' in request.auth.token && request.auth.token.admin == true) ||
             (hasUserDoc() && (getUser().get('role', '') == 'super_admin' || getUser().get('role', '') == 'admin'));
    }

    function isAdminDelegation(delegationId) {
      return isSignedIn() &&
             hasUserDoc() &&
             (getUser().get('role', '') == 'admin_delegation' || getUser().get('role', '') == 'admin' || getUser().get('role', '') == 'super_admin') &&
             getUser().get('delegation_id', '') == delegationId;
    }

    // Antenne-scoped admin: manages a single antenne (matched by delegation_id + antenne_id).
    // antenne_id must be a non-empty exact match to avoid granting blanket access.
    function isAdminAntenneOf(delegationId, antenneId) {
      return isSignedIn() &&
             hasUserDoc() &&
             getUser().get('role', '') == 'admin_antenne' &&
             getUser().get('antenne_id', '') != '' &&
             antenneId != '' &&
             getUser().get('antenne_id', '') == antenneId &&
             getUser().get('delegation_id', '') == delegationId;
    }

    // True when the signed-in user's e-mail has a matching antenne invitation
    // for the antenne/delegation carried by `data` (used for self-provisioning
    // into the admin_antenne role on first login).
    function hasMatchingInvite(data) {
      return isSignedIn() &&
             request.auth.token != null &&
             'email' in request.auth.token &&
             request.auth.token.email != null &&
             exists(/databases/$(database)/documents/antenne_invites/$(request.auth.token.email.lower())) &&
             get(/databases/$(database)/documents/antenne_invites/$(request.auth.token.email.lower())).data.get('antenne_id', '') == data.get('antenne_id', '') &&
             get(/databases/$(database)/documents/antenne_invites/$(request.auth.token.email.lower())).data.get('delegation_id', '') == data.get('delegation_id', '');
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // --- Validation Helpers ---
    function isValidDelegation(data) {
      return data.keys().hasAll(['name']) &&
             data.keys().size() == 1 &&
             data.get('name', '') is string && data.get('name', '').size() > 0 && data.get('name', '').size() <= 100;
    }

    function isValidAntenne(data) {
      return data.get('name', '') is string && data.get('name', '').size() > 0 && data.get('name', '').size() <= 100 &&
             data.get('delegation_id', '') is string && data.get('delegation_id', '').size() <= 128 &&
             (!('x' in data) || data.x == null || data.x is number) &&
             (!('y' in data) || data.y == null || data.y is number) &&
             (!('createdAt' in data) || data.createdAt is number) &&
             (!('deleted' in data) || data.deleted is bool) &&
             (!('updatedAt' in data) || data.updatedAt is number);
    }

    function isValidOrganization(data) {
      return data.get('name', '') is string && data.get('name', '').size() > 0 && data.get('name', '').size() <= 100 &&
             data.get('email', '') is string && data.get('email', '').size() > 0 && data.get('email', '').size() <= 150 &&
             data.get('submissionStatus', '') in ['Pending', 'Under review', 'Validated', 'Incomplete'] &&
             data.get('role', '') in ['organization', 'admin_delegation', 'admin_antenne', 'super_admin', 'admin'] &&
             (!('contactName' in data) || data.contactName == null || (data.contactName is string && data.contactName.size() <= 100)) &&
             (!('phone' in data) || data.phone == null || (data.phone is string && data.phone.size() <= 50)) &&
             (!('createdAt' in data) || data.createdAt is number) &&
             (!('updatedAt' in data) || data.updatedAt is number) &&
             (!('delegation_id' in data) || data.delegation_id == null || data.delegation_id is string) &&
             (!('antenne_id' in data) || data.antenne_id == null || data.antenne_id is string);
    }

    function isValidFile(data) {
      return data.keys().hasAll(['orgId', 'name', 'size', 'type', 'storagePath', 'uploadDate', 'delegation_id', 'antenne_id', 'submissionStatus']) &&
             data.get('orgId', '') is string && data.get('orgId', '').size() <= 128 &&
             data.get('name', '') is string && data.get('name', '').size() > 0 && data.get('name', '').size() <= 1000 &&
             data.get('size', 0) is number && data.get('size', 0) > 0 &&
             data.get('type', '') is string && data.get('type', '').size() > 0 && data.get('type', '').size() <= 250 &&
             data.get('storagePath', '') is string && data.get('storagePath', '').size() > 0 && data.get('storagePath', '').size() <= 600 &&
             data.get('uploadDate', 0) is number &&
             (data.get('delegation_id', null) == null || (data.get('delegation_id', '') is string && data.get('delegation_id', '').size() <= 128)) &&
             (data.get('antenne_id', null) == null || (data.get('antenne_id', '') is string && data.get('antenne_id', '').size() <= 128)) &&
             data.get('submissionStatus', '') in ['Pending', 'Under review', 'Validated', 'Incomplete'] &&
             (!('folderId' in data) || data.folderId == null || (data.folderId is string && data.folderId.size() <= 128)) &&
             (!('uploadedBy' in data) || data.uploadedBy in ['admin', 'user', 'public']) &&
             (!('fallbackDataUrl' in data) || data.fallbackDataUrl == null || data.fallbackDataUrl is string);
    }

    function isValidAntenneGroup(data) {
      return data.get('name', '') is string && data.get('name', '').size() > 0 && data.get('name', '').size() <= 100 &&
             data.get('antenneIds', []) is list &&
             (!('color' in data) || data.color == null || (data.color is string && data.color.size() <= 20)) &&
             (!('createdAt' in data) || data.createdAt is number) &&
             (!('updatedAt' in data) || data.updatedAt is number);
    }

    function isValidInvite(data) {
      return data.get('email', '') is string && data.get('email', '').size() > 0 && data.get('email', '').size() <= 150 &&
             data.get('delegation_id', '') is string && data.get('delegation_id', '').size() > 0 && data.get('delegation_id', '').size() <= 128 &&
             data.get('antenne_id', '') is string && data.get('antenne_id', '').size() > 0 && data.get('antenne_id', '').size() <= 128 &&
             (!('createdAt' in data) || data.createdAt is number);
    }

    function isValidAntenneSettings(data) {
      return (!('notifyEmail' in data) || data.notifyEmail == null || (data.notifyEmail is string && data.notifyEmail.size() <= 150)) &&
             (!('notifyEnabled' in data) || data.notifyEnabled is bool) &&
             (!('updatedAt' in data) || data.updatedAt is number);
    }

    // Liste blanche des actions journalisables (anti-pollution du journal).
    function isKnownAuditAction(a) {
      return a in [
        'login', 'logout',
        'file_upload', 'file_delete', 'file_status_change', 'file_share_toggle', 'file_rename',
        'folder_create', 'folder_delete',
        'org_create', 'org_delete', 'org_role_change', 'org_status_change', 'org_assign_antenne', 'org_profile_update',
        'antenne_create', 'antenne_delete', 'antenne_settings_change'
      ];
    }

    // Actions qu'un compte partenaire (rôle organization) peut légitimement
    // journaliser pour lui-même : il ne peut pas forger des actions d'admin
    // (changement de rôle, suppression de compte, etc.).
    function isPartnerAuditAction(a) {
      return a in ['login', 'logout', 'file_upload', 'file_delete', 'folder_create', 'folder_delete', 'file_rename'];
    }

    function isValidAuditLog(data) {
      return data.keys().hasOnly(['timestamp', 'actorUid', 'actorName', 'actorRole', 'action',
                                  'targetType', 'targetId', 'targetName', 'delegation_id', 'antenne_id', 'details']) &&
             data.keys().hasAll(['timestamp', 'actorUid', 'actorName', 'actorRole', 'action']) &&
             data.get('actorUid', '') is string && data.get('actorUid', '').size() <= 128 &&
             data.get('timestamp', 0) is number &&
             data.get('action', '') is string && isKnownAuditAction(data.get('action', '')) &&
             data.get('actorName', '') is string && data.get('actorName', '').size() <= 250 &&
             data.get('actorRole', '') is string && data.get('actorRole', '').size() <= 40 &&
             (data.get('antenne_id', null) == null || (data.get('antenne_id', '') is string && data.get('antenne_id', '').size() <= 128)) &&
             (data.get('delegation_id', null) == null || (data.get('delegation_id', '') is string && data.get('delegation_id', '').size() <= 128)) &&
             (data.get('targetType', null) == null || (data.get('targetType', '') is string && data.get('targetType', '').size() <= 50)) &&
             (data.get('targetId', null) == null || (data.get('targetId', '') is string && data.get('targetId', '').size() <= 128)) &&
             (data.get('targetName', null) == null || (data.get('targetName', '') is string && data.get('targetName', '').size() <= 1000)) &&
             (data.get('details', null) == null || (data.get('details', '') is string && data.get('details', '').size() <= 2000));
    }

    function isValidMail(data) {
      return data.get('to', []) is list && data.get('to', []).size() > 0 && data.get('to', []).size() <= 50 &&
             data.get('message', {}) is map &&
             data.message.get('subject', '') is string && data.message.get('subject', '').size() <= 300 &&
             data.message.get('text', '') is string && data.message.get('text', '').size() <= 20000 &&
             (!('html' in data.message) || (data.message.html is string && data.message.html.size() <= 50000));
    }

    function isValidFolder(data) {
      return data.keys().hasAll(['orgId', 'name', 'createdAt', 'createdBy']) &&
             data.get('orgId', '') is string && data.get('orgId', '').size() <= 128 &&
             data.get('name', '') is string && data.get('name', '').size() > 0 && data.get('name', '').size() <= 200 &&
             data.get('createdAt', 0) is number &&
             data.get('createdBy', '') in ['user', 'admin'] &&
             (!('delegation_id' in data) || data.delegation_id == null || data.delegation_id is string) &&
             (!('antenne_id' in data) || data.antenne_id == null || data.antenne_id is string);
    }

    // --- Collections Match Rules ---

    // 1. Delegations
    match /delegations/{delegationId} {
      allow read: if true;
      allow create, update, delete: if isSuperAdmin() && isValidDelegation(incoming());
    }

    // 2. Antennes
    match /antennes/{antenneId} {
      allow read: if true; 
      allow create, update: if (isSuperAdmin() && isValidAntenne(incoming())) || 
                               (isSignedIn() && isValidAntenne(incoming()) && isAdminDelegation(incoming().get('delegation_id', '')));
      allow delete: if isSuperAdmin();
    }

    // 2b. Antenne Groups (thematic groupings, super admin only for writes)
    match /antenne_groups/{groupId} {
      allow read: if true;
      allow create, update: if isSuperAdmin() && isValidAntenneGroup(incoming());
      allow delete: if isSuperAdmin();
    }

    // 2c. Antenne admin invitations (email -> antenne). Super admin manages
    // them; a signed-in user may read only the invitation for their own email.
    match /antenne_invites/{inviteId} {
      allow get: if isSuperAdmin() ||
                    (isSignedIn() && request.auth.token != null && 'email' in request.auth.token &&
                     request.auth.token.email != null && request.auth.token.email.lower() == inviteId);
      allow list: if isSuperAdmin();
      allow create, update: if isSuperAdmin() && isValidInvite(incoming());
      allow delete: if isSuperAdmin();
    }

    // 2c-bis. Réglages par antenne (notifications e-mail). Lisible par tout
    // utilisateur connecté (les partenaires lisent pour savoir où notifier),
    // modifiable par le super admin, le gestionnaire de l'antenne, ou un
    // coordinateur de la délégation.
    match /antenne_settings/{antenneId} {
      allow get: if isSignedIn();
      allow list: if isSuperAdmin();
      allow create, update: if isValidAntenneSettings(incoming()) && (
                              isSuperAdmin() ||
                              (hasUserDoc() && getUser().get('role', '') == 'admin_antenne' && getUser().get('antenne_id', '') == antenneId) ||
                              (hasUserDoc() && getUser().get('role', '') == 'admin_delegation')
                            );
      allow delete: if isSuperAdmin();
    }

    // 2d. Mail queue (extension Firebase "Trigger Email from Firestore").
    // Le super admin peut déposer un e-mail à envoyer ; l'extension le traite
    // côté serveur (admin SDK, hors règles).
    match /mail/{mailId} {
      allow get, list: if isSuperAdmin();
      allow create: if isSuperAdmin() && isValidMail(incoming());
      allow update, delete: if false;
    }

    // 2e. Journal d'activité (audit logs).
    //  - création : tout compte connecté peut journaliser SES PROPRES actions
    //    (actorUid doit être l'utilisateur courant).
    //  - lecture : le super admin voit tout ; un gestionnaire / coordinateur
    //    d'antenne ne voit que les logs de SON antenne.
    //  - logs immuables : ni modification ni suppression.
    match /audit_logs/{logId} {
      // Un compte ne journalise QUE ses propres actions (actorUid == uid courant),
      // et un partenaire (organization) est limité aux actions qu'il peut
      // réellement effectuer (pas de forge d'actions d'administration).
      allow create: if isSignedIn() && isValidAuditLog(incoming()) &&
                       incoming().get('actorUid', '') == request.auth.uid &&
                       (
                         !(hasUserDoc() && getUser().get('role', '') == 'organization') ||
                         isPartnerAuditAction(incoming().get('action', ''))
                       );

      allow get, list: if isSuperAdmin() ||
                          (isSignedIn() && hasUserDoc() &&
                           (getUser().get('role', '') == 'admin_antenne' || getUser().get('role', '') == 'admin_delegation') &&
                           getUser().get('antenne_id', '') != '' &&
                           resource.data.get('antenne_id', '') == getUser().get('antenne_id', ''));

      allow update, delete: if false;
    }

    // 3. Organizations (Users / Partners Profiles)
    match /organizations/{orgId} {
      allow get: if isOwner(orgId) || isSuperAdmin() || (isSignedIn() && hasUserDoc() && (getUser().get('role', '') == 'admin_delegation' || getUser().get('role', '') == 'admin' || getUser().get('role', '') == 'super_admin') && getUser().get('delegation_id', '') == existing().get('delegation_id', '')) || isAdminAntenneOf(existing().get('delegation_id', ''), existing().get('antenne_id', ''));
      allow list: if isSuperAdmin() || (isSignedIn() && hasUserDoc() && (getUser().get('role', '') == 'admin_delegation' || getUser().get('role', '') == 'admin' || getUser().get('role', '') == 'super_admin')) || isAdminAntenneOf(resource.data.get('delegation_id', ''), resource.data.get('antenne_id', ''));
      
      allow create: if isSignedIn() &&
                    isValidId(orgId) &&
                    isOwner(orgId) &&
                    isValidOrganization(incoming()) &&
                    (incoming().get('role', '') == 'organization' ||
                     isSuperAdmin() ||
                     (incoming().get('role', '') == 'admin_antenne' && hasMatchingInvite(incoming())));
      
      allow update: if isSignedIn() && isValidId(orgId) && isValidOrganization(incoming()) && (
                    isSuperAdmin() ||
                    // Coordinateur de délégation : gère les comptes de sa délégation,
                    // mais jamais les comptes du personnel (super admin / admin) et ne
                    // peut promouvoir personne à ces rôles (anti-escalade).
                    (hasUserDoc() && getUser().get('role', '') == 'admin_delegation' &&
                      existing().get('role', '') != 'super_admin' && existing().get('role', '') != 'admin' &&
                      incoming().get('role', '') != 'super_admin' && incoming().get('role', '') != 'admin' && (
                      // Either they manage the existing delegation
                      getUser().get('delegation_id', '') == existing().get('delegation_id', '') ||
                      // Or they are adopting an orphan account into their own delegation
                      (getUser().get('delegation_id', '') == incoming().get('delegation_id', '') && (!('delegation_id' in existing()) || existing().get('delegation_id', '') == null || existing().get('delegation_id', '') == ''))
                    )) ||
                    (isAdminAntenneOf(existing().get('delegation_id', ''), existing().get('antenne_id', '')) && incoming().diff(existing()).affectedKeys().hasOnly(['submissionStatus', 'updatedAt'])) ||
                    (isOwner(orgId) && incoming().get('role', '') == 'admin_antenne' && hasMatchingInvite(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['role', 'delegation_id', 'antenne_id', 'updatedAt'])) ||
                    (isOwner(orgId) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'contactName', 'email', 'phone', 'updatedAt']))
                  );

      // Suppression d'un compte : super admin partout ; un coordinateur de
      // délégation peut supprimer un compte (non-personnel) de sa délégation.
      allow delete: if isSuperAdmin() ||
                    (isSignedIn() && hasUserDoc() && getUser().get('role', '') == 'admin_delegation' &&
                     getUser().get('delegation_id', '') == existing().get('delegation_id', '') &&
                     existing().get('role', '') != 'super_admin' && existing().get('role', '') != 'admin');
    }

    // 4. Folders
    match /folders/{folderId} {
      allow get: if isSignedIn() && (
                    existing().get('orgId', '') == request.auth.uid ||
                    isSuperAdmin() ||
                    isAdminAntenneOf(existing().get('delegation_id', ''), existing().get('antenne_id', '')) ||
                    (hasUserDoc() && (
                      (getUser().get('role', '') == 'admin_delegation' && getUser().get('delegation_id', '') == existing().get('delegation_id', '')) ||
                      (getUser().get('role', '') == 'admin' || getUser().get('role', '') == 'super_admin') ||
                      (getUser().get('delegation_id', '') == existing().get('delegation_id', '') && (existing().get('createdBy', '') == 'admin' || existing().get('orgId', '') == 'admin_created' || existing().get('orgId', '') == 'public'))
                    ))
                  );

      allow list: if isSignedIn() && (
                     resource.data.get('orgId', '') == request.auth.uid ||
                     isSuperAdmin() ||
                     isAdminAntenneOf(resource.data.get('delegation_id', ''), resource.data.get('antenne_id', '')) ||
                     (hasUserDoc() && (
                       (getUser().get('role', '') == 'admin_delegation' && getUser().get('delegation_id', '') == resource.data.get('delegation_id', '')) ||
                       (getUser().get('role', '') == 'admin' || getUser().get('role', '') == 'super_admin') ||
                       (getUser().get('delegation_id', '') == resource.data.get('delegation_id', '') && (resource.data.get('createdBy', '') == 'admin' || resource.data.get('orgId', '') == 'admin_created' || resource.data.get('orgId', '') == 'public'))
                     ))
                   );

      allow create: if isSignedIn() && isValidFolder(incoming()) && (
                      incoming().get('orgId', '') == request.auth.uid ||
                      isSuperAdmin() ||
                      isAdminAntenneOf(incoming().get('delegation_id', ''), incoming().get('antenne_id', '')) ||
                      (hasUserDoc() && (
                        (getUser().get('role', '') == 'admin_delegation' && getUser().get('delegation_id', '') == incoming().get('delegation_id', '')) ||
                        (getUser().get('role', '') == 'admin' || getUser().get('role', '') == 'super_admin')
                      ))
                    );

      allow update: if isSignedIn() && isValidFolder(incoming()) && (
                      isSuperAdmin() ||
                      existing().get('orgId', '') == request.auth.uid ||
                      isAdminAntenneOf(existing().get('delegation_id', ''), existing().get('antenne_id', '')) ||
                      (hasUserDoc() && (
                        (getUser().get('role', '') == 'admin_delegation' && getUser().get('delegation_id', '') == existing().get('delegation_id', '')) ||
                        (getUser().get('role', '') == 'admin' || getUser().get('role', '') == 'super_admin')
                      ))
                    );

      allow delete: if isSignedIn() && (
                    existing().get('orgId', '') == request.auth.uid ||
                    isSuperAdmin() ||
                    isAdminAntenneOf(existing().get('delegation_id', ''), existing().get('antenne_id', '')) ||
                    (hasUserDoc() && (
                      (getUser().get('role', '') == 'admin_delegation' && getUser().get('delegation_id', '') == existing().get('delegation_id', '')) ||
                      (getUser().get('role', '') == 'admin' || getUser().get('role', '') == 'super_admin')
                    ))
                  );
    }

    // 5. Files Documents
    match /files/{fileId} {
      allow get: if isSignedIn() && (
                    existing().get('orgId', '') == request.auth.uid ||
                    isSuperAdmin() ||
                    isAdminAntenneOf(existing().get('delegation_id', ''), existing().get('antenne_id', '')) ||
                    (hasUserDoc() && (
                      (getUser().get('role', '') == 'admin_delegation' && getUser().get('delegation_id', '') == existing().get('delegation_id', '')) ||
                      (getUser().get('role', '') == 'admin' || getUser().get('role', '') == 'super_admin') ||
                      (getUser().get('delegation_id', '') == existing().get('delegation_id', '') && (existing().get('uploadedBy', '') == 'admin' || existing().get('orgId', '') == 'admin_created' || existing().get('orgId', '') == 'public'))
                    ))
                  );

      allow list: if isSignedIn() && (
                     resource.data.get('orgId', '') == request.auth.uid ||
                     isSuperAdmin() ||
                     isAdminAntenneOf(resource.data.get('delegation_id', ''), resource.data.get('antenne_id', '')) ||
                     (hasUserDoc() && (
                       (getUser().get('role', '') == 'admin_delegation' && getUser().get('delegation_id', '') == resource.data.get('delegation_id', '')) ||
                       (getUser().get('role', '') == 'admin' || getUser().get('role', '') == 'super_admin') ||
                       (getUser().get('delegation_id', '') == resource.data.get('delegation_id', '') && (resource.data.get('uploadedBy', '') == 'admin' || resource.data.get('orgId', '') == 'admin_created' || resource.data.get('orgId', '') == 'public'))
                     ))
                   );

      allow create: if isSignedIn() && isValidFile(incoming()) && (
                      // Le propriétaire ne peut déposer QUE si son compte est validé
                      // (un nouveau compte « En attente » ou suspendu ne peut pas déposer).
                      (incoming().get('orgId', '') == request.auth.uid && hasUserDoc() && getUser().get('submissionStatus', '') == 'Validated') ||
                      isSuperAdmin() ||
                      isAdminAntenneOf(incoming().get('delegation_id', ''), incoming().get('antenne_id', '')) ||
                      (hasUserDoc() && (
                        (getUser().get('role', '') == 'admin_delegation' && getUser().get('delegation_id', '') == incoming().get('delegation_id', '')) ||
                        (getUser().get('role', '') == 'admin' || getUser().get('role', '') == 'super_admin')
                      ))
                    );

      allow update: if isValidFile(incoming()) && (
                    isSuperAdmin() ||
                    (isSignedIn() && existing().get('orgId', '') == request.auth.uid) ||
                    isAdminAntenneOf(existing().get('delegation_id', ''), existing().get('antenne_id', '')) ||
                    (isSignedIn() && hasUserDoc() && (
                      (getUser().get('role', '') == 'admin_delegation' && getUser().get('delegation_id', '') == existing().get('delegation_id', '')) ||
                      (getUser().get('role', '') == 'admin' || getUser().get('role', '') == 'super_admin')
                    ))
                  );

      allow delete: if isSignedIn() && (
                    existing().get('orgId', '') == request.auth.uid ||
                    isSuperAdmin() ||
                    isAdminAntenneOf(existing().get('delegation_id', ''), existing().get('antenne_id', '')) ||
                    (hasUserDoc() && (
                      (getUser().get('role', '') == 'admin_delegation' && getUser().get('delegation_id', '') == existing().get('delegation_id', '')) ||
                      (getUser().get('role', '') == 'admin' || getUser().get('role', '') == 'super_admin')
                    ))
                  );

      match /chunks/{chunkId} {
        allow read, write: if isSuperAdmin() ||
                             (isSignedIn() && get(/databases/$(database)/documents/files/$(fileId)).data.get('orgId', '') == request.auth.uid) ||
                             isAdminAntenneOf(get(/databases/$(database)/documents/files/$(fileId)).data.get('delegation_id', ''), get(/databases/$(database)/documents/files/$(fileId)).data.get('antenne_id', '')) ||
                             (isSignedIn() && hasUserDoc() && (getUser().get('role', '') == 'admin_delegation' || getUser().get('role', '') == 'admin' || getUser().get('role', '') == 'super_admin'));
      }
    }
  }
}
